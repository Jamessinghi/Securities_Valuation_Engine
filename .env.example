# Copy this file to `.env` and paste your free API keys.
# `.env` is git-ignored, so keys never reach the public repo.

# Finnhub (analyst consensus, price targets) — https://finnhub.io  (free tier)
FINNHUB_API_KEY=

# FRED (risk-free yields + macro factors) — https://fred.stlouisfed.org/docs/api  (free key)
FRED_API_KEY=

# EODHD (optional ASX/global EOD fallback; free tier: 20 calls/day, one-year history)
# https://eodhd.com/register
EODHD_API_KEY=

# Comma-separated browser origins allowed to call FastAPI.
# Production example: https://jamessinghi.github.io
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Optional overrides
# HOST=127.0.0.1
# PORT=8000
